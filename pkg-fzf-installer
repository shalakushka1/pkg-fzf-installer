#!/usr/bin/env bash

# Force fzf shell to bash to avoid 'invalid argument' errors
export SHELL=/usr/bin/bash

# Allow the script to continue even if a command returns a non-zero exit code
set +e

# Function to show a completion message and wait for user input
wait_message() {
  echo
  if command -v gum &>/dev/null; then
    # Using the "points" spinner as requested
    gum spin --spinner "points" --title " Done! Press any key to close..." -- bash -c 'read -n 1 -s'
  else
    echo -e "\n Done! Press any key to close..."
    read -n 1 -s
  fi
}

# --- OPERATION MODES ---

# Interactive system cleanup
clean_system() {
  echo -e "\n--- Cleaning system cache and orphan packages ---"
  
  # List and remove orphans if any exist
  orphans=$(pacman -Qtdq)
  if [[ -n "$orphans" ]]; then
    echo -e "\nOrphan packages found. Starting interactive removal..."
    sudo pacman -Rns $orphans
  else
    echo "No orphan packages found to remove."
  fi

  # Clean pacman cache (Interactive - asks for [Y/n])
  echo -e "\n--- Cleaning Pacman cache ---"
  sudo pacman -Sc

  # Clean paru/AUR cache (Interactive)
  echo -e "\n--- Cleaning Paru (AUR) cache ---"
  paru -Sc
  
  wait_message
}

# Full system update (Repositories + AUR)
update_system() {
  echo -e "\n--- Starting Full System Update (Repos + AUR) ---"
  # Paru automatically handles both official and AUR updates
  paru
  wait_message
}

# Official repository package installer
pacman_mode() {
  pkg_names=$(pacman -Slq | sort -u | fzf \
    --multi \
    --prompt="Install ❯ " \
    --marker="+" --pointer="❯" \
    --preview 'pacman -Si {1}' \
    --preview-label='[ INFO ]' \
    --preview-window 'down:65%:wrap' \
    --bind 'alt-j:preview-down,alt-k:preview-up')

  if [[ -n "$pkg_names" ]]; then
    # Use -o to keep the TTY open for pacman prompts
    echo "$pkg_names" | xargs -r -o sudo pacman -S
    wait_message
  fi
}

# Package uninstaller
remove_mode() {
  pkg_names=$(pacman -Qqe | sort | fzf \
    --multi \
    --prompt="Remove ❯ " \
    --marker="-" --pointer="❯" \
    --preview 'pacman -Qi {1}' \
    --preview-label='[ INFO ]' \
    --preview-window 'down:65%:wrap' \
    --bind 'alt-j:preview-down,alt-k:preview-up')

  if [[ -n "$pkg_names" ]]; then
    echo "$pkg_names" | xargs -r -o sudo pacman -Rns
    wait_message
  fi
}

# AUR-exclusive package installer
aur_mode() {
  # Exclusive AUR search using the -a flag
  pkg_names=$(echo "" | fzf \
    --multi \
    --height=100% \
    --layout=default \
    --border \
    --prompt="AUR ❯ " \
    --header "Type to search | TAB: select | ALT-P: Info | ALT-B: PKGBUILD" \
    --bind "change:reload(paru -Ssq -a {q} || true)" \
    --preview '[[ -n {} ]] && paru -Si {1}' \
    --preview-label='[ INFO ]' \
    --preview-window 'down:65%:wrap' \
    --bind 'alt-p:change-preview(paru -Si {1})' \
    --bind 'alt-b:change-preview(paru -Gp {1})' \
    --bind 'alt-j:preview-down,alt-k:preview-up')

  if [[ -n "$pkg_names" ]]; then
    echo -e "\nInstalling from AUR:"
    echo "$pkg_names" | xargs -r -o paru -a -S
    wait_message
  fi
}

# --- MENUS ---

# Secondary menu for system maintenance
management_menu() {
  while true; do
    choice=$(printf "Update System\nClean Cache and Orphans\nRemove Packages\nBack" | \
      fzf \
      --prompt="Management ❯ " \
      --height=100% \
      --layout=reverse \
      --border \
      --cycle)

    case "$choice" in
      "Update System") update_system ;;
      "Clean Cache and Orphans") clean_system ;;
      "Remove Packages") remove_mode ;;
      "Back"|*) return ;;
    esac
  done
}

# Primary entry point
main_menu() {
  while true; do
    choice=$(printf "Install Official Packages\nInstall AUR Packages\nSystem Management\nExit" | \
      fzf \
      --prompt="Main Menu ❯ " \
      --height=100% \
      --layout=reverse \
      --border \
      --cycle)

    case "$choice" in
      "Install Official Packages") pacman_mode ;;
      "Install AUR Packages") aur_mode ;;
      "System Management") management_menu ;;
      "Exit"|*) clear; exit 0 ;;
    esac
  done
}

# Entry point
clear
main_menu
